        <Prompt>Simulink:masks:x11PropagatedDataTypeegFixdt116Fixdtsingle_MP</Prompt>
        <Value>fixdt(1, 16)</Value>
        <Callback>fixptdialog(gcbh)</Callback>
        <TabName>Simulink:masks:Propagatedtype</TabName>
      </MaskParameter>
      <MaskParameter Name="IfRefDouble" Type="popup" Tunable="off">
        <Prompt>Simulink:masks:x11IfAnyReferenceInputIsDoubleOutputIs_MP</Prompt>
        <Value>double</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
        <TypeOptions>
          <Option>Simulink:masks:double</Option>
          <Option>Simulink:masks:single</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="IfRefSingle" Type="popup" Tunable="off">
        <Prompt>Simulink:masks:x12IfAnyReferenceInputIsSingleOutputIs_MP</Prompt>
        <Value>single</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
        <TypeOptions>
          <Option>Simulink:masks:double</Option>
          <Option>Simulink:masks:single</Option>
        </TypeOptions>
      </MaskParameter>
