        <Value>NumBits1</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
        <TypeOptions>
          <Option>NumBits1</Option>
          <Option>NumBits2</Option>
          <Option>max([NumBits1 NumBits2])</Option>
          <Option>min([NumBits1 NumBits2])</Option>
          <Option>NumBits1+NumBits2</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="NumBitsMult" Type="edit" Tunable="off">
        <Prompt>Simulink:masks:x142NumberofBitsMultiplicativeAdjustment_MP</Prompt>
        <Value>1</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
      </MaskParameter>
      <MaskParameter Name="NumBitsAdd" Type="edit" Tunable="off">
        <Prompt>Simulink:masks:x143NumberofBitsAdditiveAdjustment_MP</Prompt>
        <Value>0</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
      </MaskParameter>
      <MaskParameter Name="NumBitsAllowFinal" Type="edit" Tunable="off">
        <Prompt>Simulink:masks:x144NumberofBitsAllowableFinalValues_MP</Prompt>
        <Value>1:128</Value>
        <TabName>Simulink:masks:Propagatedtype</TabName>
      </MaskParameter>
      <MaskParameter Name="PropScalingMode" Type="popup" Tunable="off">
        <Prompt>Simulink:masks:x2PropagatedScaling_MP</Prompt>
        <Value>Inherit via propagation rule</Value>
        <Callback>fixptdialog(gcbh)</Callback>
        <TabName>Simulink:masks:Propagatedscaling</TabName>
        <TypeOptions>
          <Option>Simulink:masks:SpecifyViaDialog</Option>
          <Option>Simulink:masks:InheritViaPropagationRule</Option>
          <Option>Simulink:masks:ObtainViaBestPrecision</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="PropScaling" Type="edit" Tunable="off" Visible="off">
        <Prompt>Simulink:masks:x21PropagatedScalingSlopeEg29OrSlopeBiasEg1253_MP</Prompt>
        <Value>2^-10</Value>
        <TabName>Simulink:masks:Propagatedscaling</TabName>
      </MaskParameter>
      <MaskParameter Name="ValuesUsedBestPrec" Type="edit" Tunable="off" Visible="off">
        <Prompt>Simulink:masks:x21ValuesUsedToDetermineBestPrecisionScaling_MP</Prompt>
        <Value>[5 -7]</Value>
