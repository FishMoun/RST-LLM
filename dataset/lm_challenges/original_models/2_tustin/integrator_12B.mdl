    <P Name="RndMeth">Zero</P>
  </Block>
  <Block BlockType="SubSystem" Name="Saturation&#xA;Dynamic" SID="93">
    <PortCounts in="3" out="1"/>
    <P Name="Position">[765, 245, 845, 285]</P>
    <P Name="ZOrder">-11</P>
    <Mask SelfModifiable="on">
      <Type>Saturation Dynamic</Type>
      <Display IconOpaque="transparent" RunInitForIconRedraw="off" IconUnits="normalized"/>
      <Description>Simulink:masks:SaturationDynamic_MD</Description>
      <Initialization>blkH = gcbh;
blkName = getfullname(blkH);

switch_blks = {&apos;Switch&apos;,&apos;Switch2&apos;}; 
for i = 1:length(switch_blks)
  set_param([blkName,&apos;/&apos;,switch_blks{i}], ...
      &apos;RndMeth&apos;, RndMeth, ...
	  &apos;DoSatur&apos;, DoSatur);
end

propBlk = [blkName, &apos;/Data Type Propagation&apos;];

if strcmp(OutputDataTypeScalingMode, &apos;Same as second input&apos;)
    set_param(propBlk, &apos;PropDataTypeMode&apos;, &apos;Inherit via propagation rule&apos;, ...
                       &apos;PropScalingMode&apos;,  &apos;Inherit via propagation rule&apos;);
else
    scaling = OutScaling;
    scalingMode = &apos;Specify via dialog&apos;;
    switch OutputDataTypeScalingMode
      case &apos;double&apos;
        dataType = &apos;fixdt(&apos;&apos;double&apos;&apos;)&apos;;
      case &apos;single&apos;
        dataType = &apos;fixdt(&apos;&apos;single&apos;&apos;)&apos;;
      case &apos;int8&apos;
        dataType = &apos;fixdt(1,8,0)&apos;;
      case &apos;uint8&apos;
        dataType = &apos;fixdt(0,8,0)&apos;;
      case &apos;int16&apos;
        dataType = &apos;fixdt(1,16,0)&apos;;
      case &apos;uint16&apos;
        dataType = &apos;fixdt(0,16,0)&apos;;
      case &apos;int32&apos;
        dataType = &apos;fixdt(1,32,0)&apos;;
      case &apos;uint32&apos;
        dataType = &apos;fixdt(0,32,0)&apos;;
      case &apos;Specify via dialog&apos;
        dataType = OutDataType;
        if ~isempty(OutDataTypeStr) &amp;&amp; isa(OutDataTypeStr,&apos;Simulink.NumericType&apos;) 
          if strcmp(OutDataTypeStr.DataTypeMode, &apos;Fixed-point: unspecified scaling&apos;) 
            scalingMode = &apos;Obtain via best precision&apos;;
            range = [OutMin OutMax];
            range = range(~isinf(range));
            set_param(propBlk, &apos;ValuesUsedBestPrec&apos;, mat2str(range));
          end
        end
    end
    
    set_param(propBlk, &apos;PropDataTypeMode&apos;, &apos;Specify via dialog&apos;, ...
                       &apos;PropScalingMode&apos;,  scalingMode, ...
                       &apos;PropDataType&apos;,     dataType, ...
                       &apos;PropScaling&apos;,      scaling);
end
    
</Initialization>
      <Capabilities>slmaskedcaps(gcbh)</Capabilities>
      <BlockDVGIcon>BlockIcon.Saturate</BlockDVGIcon>
      <MaskParameter Name="OutMin" Type="min" Tunable="off">
        <Prompt>Simulink:masks:OutputMinimum_MP</Prompt>
        <Value>[]</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="OutMax" Type="max" Tunable="off">
        <Prompt>Simulink:masks:OutputMaximum_MP</Prompt>
        <Value>[]</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="OutDataTypeStr" Type="unidt({m=3|4|5||6|1|2|}{i=Inherit: Same as second input}{b=double|single|int8|uint8|int16|uint16|int32|uint32}{s=UDTBinaryPointMode|UDTSlopeBiasMode|UDTBestPrecisionMode}{g=UDTSignedSign|UDTUnsignedSign})" Tunable="off">
        <Prompt>Simulink:masks:OutputDataType_MP</Prompt>
        <Value>Inherit: Same as second input</Value>
        <Callback>fixptdialog(gcbh)</Callback>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="OutputDataTypeScalingMode" Type="popup" Evaluate="off" Tunable="off" Internal="on" Visible="off">
        <Prompt>Simulink:masks:OutputDataTypeMode_MP</Prompt>
        <Value>Same as second input</Value>
        <Callback>fixptdialog(gcbh)</Callback>
        <TabName>Simulink:masks:SignalAttributes</TabName>
        <TypeOptions>
          <Option>double</Option>
          <Option>single</Option>
          <Option>int8</Option>
          <Option>uint8</Option>
          <Option>int16</Option>
          <Option>uint16</Option>
          <Option>int32</Option>
          <Option>uint32</Option>
          <Option>Specify via dialog</Option>
          <Option>Same as second input</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="OutDataType" Type="edit" Evaluate="off" Tunable="off" Internal="on" Visible="off">
        <Prompt>Simulink:masks:OutputDataTypeegFixdt116Fixdtsingle_MP</Prompt>
        <Value>fixdt(1, 16)</Value>
        <Callback>fixptdialog(gcbh)</Callback>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="OutScaling" Type="edit" Evaluate="off" Tunable="off" Internal="on" Visible="off">
        <Prompt>Simulink:masks:OutputScalingSlopeEg29OrSlopeBias_MP</Prompt>
        <Value>2^-10</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="LockScale" Type="checkbox" Tunable="off">
        <Prompt>Simulink:masks:LockOutputDataTypeAgainstFxpTools_MP</Prompt>
        <Value>off</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
      <MaskParameter Name="RndMeth" Type="popup" Evaluate="off" Tunable="off">
        <Prompt>Simulink:masks:IntegerRoundingMode_MP</Prompt>
        <Value>Floor</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
        <TypeOptions>
          <Option>Simulink:masks:Ceiling</Option>
          <Option>Simulink:masks:Convergent</Option>
          <Option>Simulink:masks:Floor</Option>
          <Option>Simulink:masks:Nearest</Option>
          <Option>Simulink:masks:Round</Option>
          <Option>Simulink:masks:Simplest</Option>
          <Option>Simulink:masks:Zero</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="DoSatur" Type="checkbox" Evaluate="off" Tunable="off">
        <Prompt>Simulink:masks:SaturateOnIntegerOverflow_MP</Prompt>
        <Value>off</Value>
        <TabName>Simulink:masks:SignalAttributes</TabName>
      </MaskParameter>
    </Mask>
